{
  "name": "owlCode",
  "version": "1.0.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --watch packages/cli/src/index.tsx",
    "dev:server": "bun run --hot packages/server/src/index.ts",
    "dev:cli": "cd packages/cli && bun run dev",
    "build:cli": "bun run --filter @owlcode/cli build",
    "link:cli": "bun run build:cli && cd packages/cli && bun link"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "opentui-spinner": "^0.0.7"
  }
}
