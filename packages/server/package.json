{
    "name": "@owlcode/server",
    "type": "module",
    "private": "true",
    "exports": {
        ".": "./src/index.ts"
    },
    "scripts": {
        "dev": "bun run --hot src/index.ts",
        "build" : "bun build src/index.ts --outdir dist -- target bun",
        "postinstall": "bun run --cwd ../database db:generate"

    },
    "dependencies": {
        "@ai-sdk/google": "^3.0.83",
        "@ai-sdk/groq": "^3.0.42",
        "@hono/zod-validator": "^0.8.0",
        "@owlcode/database": "workspace:*",
        "@owlcode/shared": "workspace:*",
        "@sentry/bun": "^10.59.0",
        "@sentry/hono": "^10.59.0",
        "ai": "^6.0.208",
        "dotenv": "^17.4.2",
        "hono": "^4.12.26",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@types/node": "^20.6.1"
    }
}